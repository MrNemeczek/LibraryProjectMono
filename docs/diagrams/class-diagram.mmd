classDiagram
    direction LR

    namespace Domain {
        class User {
            int Id
            string FirstName
            string LastName
            string Email
            string PasswordHash
            UserRole Role
            bool IsActive
            List~Loan~ Loans
            List~Reservation~ Reservations
        }

        class Category {
            int Id
            string Name
            List~Book~ Books
            Create(name)
        }

        class Book {
            int Id
            string Title
            string Author
            Isbn Isbn
            string Description
            Category Category
            List~BookCopy~ Copies
            List~Reservation~ Reservations
            bool IsDeleted
            DateTime DeletedAt
            Create(title, author, isbn, description, category)
            UpdateDetails(title, author, isbn, description, category)
            AddCopy(inventoryNumber)
            Delete(deletedAt)
        }

        class BookCopy {
            int Id
            string InventoryNumber
            BookCopyStatus Status
            Book Book
            List~Loan~ Loans
            Create(inventoryNumber)
            Reserve()
            Borrow()
            MakeAvailable()
        }

        class Reservation {
            int Id
            User User
            Book Book
            DateOnly ReservationDate
            DateOnly PickupDeadline
            ReservationStatus Status
            Create(user, book, pickupDeadlineDays)
            Cancel()
            Fulfill()
            Expire()
        }

        class Loan {
            int Id
            User User
            BookCopy BookCopy
            Reservation Reservation
            DateOnly LoanDate
            DateOnly ReturnDate
            LoanStatus Status
            Create(user, bookCopy, reservation)
            Return()
        }

        class Isbn {
            string Value
            Create(value)
        }

        class UserRole {
            <<enumeration>>
            Reader
            Librarian
            Administrator
        }

        class BookCopyStatus {
            <<enumeration>>
            Available
            Reserved
            Borrowed
        }

        class ReservationStatus {
            <<enumeration>>
            Active
            Cancelled
            Fulfilled
            Expired
        }

        class LoanStatus {
            <<enumeration>>
            Active
            Returned
        }
    }

    namespace Application {
        class AuthenticationService {
            Register(request)
            Login(request)
        }

        class BookService {
            GetBooks(request)
            CreateBook(request)
            UpdateBook(id, request)
            DeleteBook(id)
        }

        class CategoryService {
            GetCategories()
        }

        class ReservationService {
            CreateReservation(request, user)
            CancelReservation(reservation, user)
            FulfillReservation(reservation)
        }

        class LoanService {
            GetLoans(request)
            ReturnLoan(loan)
        }

        class IUserRepository {
            <<interface>>
            Add(user)
            GetById(id)
            GetByEmail(email)
            ExistsByEmail(email)
        }

        class IBookRepository {
            <<interface>>
            Add(book)
            GetById(id)
            GetBooks(request)
            ExistsByIsbn(isbn)
        }

        class IBookCopyRepository {
            <<interface>>
            GetAvailableCopy(book)
            GetReservedCopy(book)
            GetExistingInventoryNumbers(numbers)
        }

        class ICategoryRepository {
            <<interface>>
            Add(category)
            GetByName(name)
            GetAll()
        }

        class IReservationRepository {
            <<interface>>
            Add(reservation)
            GetById(id)
            GetByUser(user)
            ExistsActive(user, book)
        }

        class ILoanRepository {
            <<interface>>
            Add(loan)
            GetById(id)
            GetByUser(user)
            GetAll(request)
        }

        class IUnitOfWork {
            <<interface>>
            SaveChanges()
        }
    }

    namespace Infrastructure {
        class UserRepository
        class BookRepository
        class BookCopyRepository
        class CategoryRepository
        class ReservationRepository
        class LoanRepository
        class LibraryDbContext
    }

    Category "1" o-- "0..*" Book : zawiera
    Book "1" *-- "0..*" BookCopy : posiada egzemplarze
    Book "1" o-- "0..*" Reservation : jest rezerwowana
    User "1" o-- "0..*" Reservation : sklada
    User "1" o-- "0..*" Loan : wypozycza
    BookCopy "1" o-- "0..*" Loan : jest wypozyczany
    Reservation "0..1" --> "0..1" Loan : prowadzi do

    Book --> Isbn
    User --> UserRole
    BookCopy --> BookCopyStatus
    Reservation --> ReservationStatus
    Loan --> LoanStatus

    AuthenticationService ..> IUserRepository
    AuthenticationService ..> IUnitOfWork
    AuthenticationService ..> User : tworzy i uwierzytelnia

    BookService ..> IBookRepository
    BookService ..> IBookCopyRepository
    BookService ..> ICategoryRepository
    BookService ..> IUnitOfWork
    BookService ..> Book : zarzadza
    BookService ..> Category : wybiera lub tworzy

    CategoryService ..> ICategoryRepository
    CategoryService ..> Category

    ReservationService ..> IReservationRepository
    ReservationService ..> IUserRepository
    ReservationService ..> IBookRepository
    ReservationService ..> IBookCopyRepository
    ReservationService ..> ILoanRepository
    ReservationService ..> IUnitOfWork
    ReservationService ..> Reservation : zarzadza
    ReservationService ..> BookCopy : zmienia status
    ReservationService ..> Loan : tworzy przy odbiorze

    LoanService ..> ILoanRepository
    LoanService ..> IUnitOfWork
    LoanService ..> Loan : zarzadza zwrotem

    IUserRepository <|.. UserRepository
    IBookRepository <|.. BookRepository
    IBookCopyRepository <|.. BookCopyRepository
    ICategoryRepository <|.. CategoryRepository
    IReservationRepository <|.. ReservationRepository
    ILoanRepository <|.. LoanRepository

    UserRepository ..> LibraryDbContext
    BookRepository ..> LibraryDbContext
    BookCopyRepository ..> LibraryDbContext
    CategoryRepository ..> LibraryDbContext
    ReservationRepository ..> LibraryDbContext
    LoanRepository ..> LibraryDbContext
